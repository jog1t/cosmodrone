{
  "name": "@cosmodrone/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/server.ts",
    "lint": "oxlint src --deny-warnings -c .oxlintrc.json",
    "format": "oxfmt --check src -c .oxfmtrc.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-ws": "^1.3.0",
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.8",
    "rivetkit": "^2.1.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
